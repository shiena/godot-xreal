[ext_resource type="Script" uid="uid://dcampreviewgd1" path="res://demo/camera_preview.gd" id="1_script"]
[ext_resource type="Shader" uid="uid://bvvu0x0a8g2cv" path="res://addons/godot_xreal/shaders/xreal_ycbcr.gdshader" id="2_ycbcr"]

; Head-locked camera preview: a 16:9 quad ~1/3 of the view at 2 m depth (the eye cameras see
; roughly +/-0.8 x +/-0.45 m there), with the YCbCr->RGB shader (orientation and the R/B swap are
; baked in as device-calibrated constants). The eye cameras invert Y (pose handedness (x,-y,z,w)),
; so on the glasses buffer +X is right but -Y is up: hence +x, -y for "top-right". Hidden until the
; first camera frame wires the Y/CbCr textures, so the not-yet-fed shader never shows as pink.
[sub_resource type="QuadMesh" id="QuadMesh_campanel"]
size = Vector2(0.5333, 0.3)

[sub_resource type="ShaderMaterial" id="ShaderMaterial_campanel"]
shader = ExtResource("2_ycbcr")

[node name="CameraPreview" type="Node3D"]
script = ExtResource("1_script")

