; Camera preview panel — reparented under the head tracker at runtime (main.gd), positioned
; top-right, 2 m in front. The eye cameras invert Y (pose handedness (x,-y,z,w)), so on the
; glasses buffer +X is right but -Y is up: hence +x, -y. Hidden until the first camera frame
; wires the Y/CbCr textures, so the not-yet-fed shader never shows as a pink placeholder.
[node name="CamPanel" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0.48, -0.3, -2)
visible = false
mesh = SubResource("QuadMesh_campanel")
material_override = SubResource("ShaderMaterial_campanel")

; Head-locked cursor driven by the phone touch controller — reparented under the head tracker
; at runtime (main.gd) so phone touches are visible in the glasses.
[node name="Cursor" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, -2)
mesh = SubResource("BoxMesh_cursor")
material_override = SubResource("CursorMat")

; Phone-IMU 3D pointer (Phase C path B). At the scene root so its aim is world-stable (driven
; by the phone), originating at the head. Hidden until the NRController starts (main.gd).
[node name="PhonePointer" type="Node3D" parent="."]
visible = false
script = ExtResource("2_pointer")
