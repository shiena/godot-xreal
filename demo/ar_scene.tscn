; Solid black background: on the XREAL optical see-through display black reads as
; transparent, so the scene appears to float over the real world.
[sub_resource type="Environment" id="Environment_demo"]
background_mode = 1
background_color = Color(0, 0, 0, 1)
ambient_light_source = 2
ambient_light_color = Color(0.6, 0.6, 0.7, 1)
ambient_light_energy = 0.6

[sub_resource type="BoxMesh" id="BoxMesh_unit"]

[sub_resource type="BoxShape3D" id="BoxShape3D_unit"]

[sub_resource type="BoxMesh" id="BoxMesh_cursor"]
size = Vector3(0.18, 0.18, 0.18)

[sub_resource type="StandardMaterial3D" id="CursorMat"]
albedo_color = Color(0.3, 0.85, 1, 1)

[node name="ARScene" type="Node3D"]
script = ExtResource("1_ar")

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = SubResource("Environment_demo")

[node name="Sun" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.866025, 0.383022, -0.321394, 0, 0.642788, 0.766044, 0.5, -0.663414, 0.55667, 0, 0, 0)

; A ring of boxes at eye level (radius 4 m) so head rotation reads as look-around. Colors are
; NOT baked here: ar_scene.gd assigns evenly spread hues from the box count at _ready, so
; adding/removing boxes in the editor recolors the ring automatically. Each box carries a
; StaticBody3D collider so the phone-pointer raycast can hit it (phone_pointer.gd resolves
; collider.get_parent() back to the MeshInstance3D).
[node name="Room" type="Node3D" parent="."]

[node name="Box0" type="MeshInstance3D" parent="Room"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, -4)
mesh = SubResource("BoxMesh_unit")

[node name="Body" type="StaticBody3D" parent="Room/Box0"]

[node name="Col" type="CollisionShape3D" parent="Room/Box0/Body"]
shape = SubResource("BoxShape3D_unit")

