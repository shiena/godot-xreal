[gd_scene load_steps=4 format=3 uid="uid://c0xrealdemo001"]

[ext_resource type="Script" uid="uid://b7gtq7lduwbnw" path="res://demo/main.gd" id="1_main"]
[ext_resource type="PackedScene" uid="uid://ardemoscene1" path="res://demo/ar_scene.tscn" id="2_ar"]
[ext_resource type="PackedScene" uid="uid://phonescreen1" path="res://demo/phone_screen.tscn" id="3_phone"]

[node name="Main" type="Node3D"]
script = ExtResource("1_main")

[node name="ARScene" parent="." instance=ExtResource("2_ar")]

[node name="PhoneScreen" parent="." instance=ExtResource("3_phone")]

[node name="UI" type="CanvasLayer" parent="."]

[node name="Panel" type="PanelContainer" parent="UI"]
visible = false
offset_left = 16.0
offset_top = 16.0
offset_right = 380.0
offset_bottom = 168.0

[node name="Margin" type="MarginContainer" parent="UI/Panel"]
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="VBox" type="VBoxContainer" parent="UI/Panel/Margin"]

[node name="Title" type="Label" parent="UI/Panel/Margin/VBox"]
text = "Godot XREAL — 3DoF demo"

[node name="Status" type="Label" parent="UI/Panel/Margin/VBox"]
text = "XREAL: querying..."

[node name="Recenter" type="Button" parent="UI/Panel/Margin/VBox"]
text = "Recenter (3DoF)"

[connection signal="pressed" from="UI/Panel/Margin/VBox/Recenter" to="." method="_on_recenter_pressed"]
[connection signal="trigger_changed" from="PhoneScreen" to="." method="_on_tc_trigger"]
[connection signal="grip_changed" from="PhoneScreen" to="." method="_on_tc_grip"]
[connection signal="menu_pressed" from="PhoneScreen" to="." method="_on_tc_menu"]
[connection signal="touchpad_moved" from="PhoneScreen" to="." method="_on_tc_touchpad"]
[connection signal="touchpad_released" from="PhoneScreen" to="." method="_on_tc_touchpad_released"]
[connection signal="hand_selected" from="PhoneScreen" to="." method="_on_tc_hand"]
