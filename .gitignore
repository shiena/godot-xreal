# Rust
/target/
# Cargo.lock is committed: this crate builds a final artifact (the GDExtension .so), so a
# pinned lockfile gives reproducible CI / release builds.

# Godot
.godot/
*.import
demo/addons/
# Godot Android build template (top-level only; NOT addons/godot_xreal/android/).
/android/
jniLibs

# Build artifacts (incl. the desktop dummy stubs built into dummy/ by
# scripts/build_dummy_libs.ps1 / .sh — build locally, don't commit)
*.dll
*.so
*.dylib
*.apk

# Local device-test artifacts / scratch
/log
/log-unity
/godot_xreal_external.png
/android_old/
/.cargo/

# Release-only addon payload (assembled in CI, shipped in the release zip)
/addons/godot_gsplat/bin/
/addons/godot_gsplat/godot_gsplat.gdextension

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db


# XREAL addon vendored binaries (AARs) — vendored locally
# (see docs/plans/android-export-plugin-migration.md), like jniLibs/*.so.
/addons/godot_xreal/android/*.aar

# XREAL host build tools (trackableImageTools — the image-tracking DB blob generator), vendored
# locally by scripts/vendor_xreal_libs.*; large SDK binaries, not committed.
/addons/godot_xreal/tools/

# Image-tracking demo assets: the generated DB blob and the reference image(s) it was built from
# (SDK-derived / large). Regenerate with scripts/build_image_db.*; the manifest reference.json is
# committed. Packed into the APK by the Godot export from the local files.
/demo/image_tracking/*.bin
/demo/image_tracking/*.jpg
/demo/image_tracking/*.png
