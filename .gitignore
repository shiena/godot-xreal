# Rust
/target/
Cargo.lock

# Godot
.godot/
*.import
demo/addons/
# Godot Android build template (top-level only; NOT addons/godot_xreal/android/).
/android/
jniLibs

# Build artifacts
*.dll
*.so
*.dylib
*.apk
# …except the committed desktop dummy GDExtension stubs (tiny, built by
# scripts/build_dummy_libs.ps1 / .sh — see dummy/gdext_dummy.c)
!/dummy/*.dll
!/dummy/*.so
!/dummy/*.dylib

# Local device-test artifacts / scratch
/log
/log-unity
/godot_xreal_external.png
/android_old/
/.cargo/

# Release-only addon payload (assembled in CI, shipped in the release zip)
/addons/godot_gsplat/bin/
/addons/godot_gsplat/godot_gsplat.gdextension

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db


# XREAL addon vendored binaries (AARs) — vendored locally
