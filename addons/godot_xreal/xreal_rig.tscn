[sub_resource type="GDScript" id="GDScript_rig"]
script/source = "extends Camera3D

## Marks this camera current at runtime only, so the editor's own camera is not
## hijacked while editing scenes that include the rig.

func _ready() -> void:
	if not Engine.is_editor_hint():
		current = true
"

